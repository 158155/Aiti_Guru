# Шаблон переменных окружения для docker compose
# Скопируйте в .env.docker и измените под вашу конфигурацию
POSTGRES_DB=aiti_guru
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

DATABASE_URL=postgresql://postgres:postgres@postgres:5432/aiti_guru
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s | %(levelname)-7s | %(name)s | %(message)s