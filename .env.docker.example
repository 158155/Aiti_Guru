# Шаблон переменных окружения для docker compose
# Скопируйте в .env.docker и измените под вашу конфигурацию
POSTGRES_DB=itpro
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

DATABASE_URL=postgresql://postgres:postgres@postgres:5432/itpro
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s | %(levelname)-7s | %(name)s | %(message)s